# Backend — required on some setups; app also uses Metro host in dev (Expo Go).
# If you still see "Network request failed", set your Mac's Wi‑Fi IP:
# EXPO_PUBLIC_API_URL=http://192.168.1.7:4000

# Google Maps — enable Maps SDK for Android + Maps SDK for iOS in Google Cloud Console.
# Restrict keys by bundle ID / SHA-1. Required for dev client / production builds; Expo Go on Android often works with dev key.
GOOGLE_MAPS_API_KEY=
# Same key as GOOGLE_MAPS_API_KEY; exposed in the app bundle for optional client-built map thumbnails.
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
