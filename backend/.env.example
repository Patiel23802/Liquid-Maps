# Any PostgreSQL you run locally (Homebrew, Postgres.app) or hosted (Neon, Supabase, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/socialise?schema=public"
JWT_ACCESS_SECRET="change-me-access-min-32-chars-long-secret"
JWT_REFRESH_SECRET="change-me-refresh-min-32-chars-different"
ACCESS_TOKEN_TTL_SEC=900
REFRESH_TOKEN_TTL_DAYS=30
PORT=4000
NODE_ENV=development
CORS_ORIGIN="http://localhost:5173,http://localhost:8081"
# Dev OTP: hardcoded test user — phone +919999000099 (or 9999000099) + code 424242 (always accepted in development)
# Any code works for all numbers if DEV_OTP_SKIP=1; or any phone if DEV_OTP_CODE matches
DEV_OTP_SKIP=0
DEV_OTP_CODE=
ADMIN_BOOTSTRAP_EMAIL=admin@socialise.local
ADMIN_BOOTSTRAP_PASSWORD=changeme123
